# =============================================================================
# DIDACTAI RENDER DEPLOYMENT CONFIGURATION
# =============================================================================
# This .env file is optimized for deployment on Render.com
# Fill in your values before deploying
#
# To get these values:
# - SECRET_KEY: Generate using `python -c "import secrets; print(secrets.token_urlsafe(50))"`
# - DATABASE_URL: Render provides this automatically when you add a PostgreSQL service
# - GEMINI_API_KEY: Get from https://aistudio.google.com/app/apikey
# =============================================================================

# =============================================================================
# DJANGO SETTINGS (REQUIRED)
# =============================================================================

# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-change-in-production

# Set to False for production
DEBUG=False

# Add your Render service URL (e.g., your-app-name.onrender.com)
ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.onrender.com

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# Render automatically provides this when you create a PostgreSQL service.
# The format is: postgresql://username:password@host:port/database_name
# Do NOT set this manually - Render will inject it as DATABASE_URL environment variable
# DATABASE_URL will be automatically picked up by dj-database-url

# =============================================================================
# STATIC & MEDIA FILES
# =============================================================================
# Render provides /opt/render/project/render/src as the working directory
RENDER_DISK_PATH=/opt/render/project/render/src

# =============================================================================
# AI CONFIGURATION (REQUIRED FOR CONTENT GENERATION)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: OpenAI (not currently used but available)
# OPENAI_API_KEY=your-openai-api-key

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL - Required for password reset)
# =============================================================================
# If not provided, emails will be printed to console (development only)

# Option 1: Gmail (requires App Password, not regular password)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-character-app-password

# Option 2: Outlook/Hotmail
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-password

# Email sender (used in "From" field)
DEFAULT_FROM_EMAIL=DidactAI <noreply@yourdomain.com>
SERVER_EMAIL=DidactAI <server@yourdomain.com>

# =============================================================================
# FILE UPLOAD SETTINGS
# =============================================================================
MAX_UPLOAD_SIZE=50000000
ALLOWED_FILE_EXTENSIONS=pdf,docx,pptx,png,jpg,jpeg

# =============================================================================
# AI GENERATION SETTINGS
# =============================================================================
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,fr,es,de,it,pt,ru,ar,zh,ja,ko,hi,tr,el

# =============================================================================
# MONITORING (OPTIONAL)
# =============================================================================
# Get your DSN from sentry.io after creating a project
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# =============================================================================
# SECURITY (ADVANCED - do not change unless you know what you're doing)
# =============================================================================
# Force HTTPS in production (Render handles SSL automatically)
SECURE_SSL_REDIRECT=True

# =============================================================================
# RENDER BUILD COMMAND
# =============================================================================
# Build Command: pip install -r requirements.txt
#
# RENDER START COMMAND
# =============================================================================
# Start Command: gunicorn didactia_project.asgi --worker-class=uvicorn.workers.UvicornWorker --bind 0.0.0.0:$PORT